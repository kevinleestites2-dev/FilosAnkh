# FilosAnkh — Environment Variables
# Copy to .env and fill in your values

# ── LightAgent / Ollama ──────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
LIGHTAGENT_MODEL=llama3.1
LIGHTAGENT_API_KEY=ollama

# ── Telegram (Daemon proactive messages) ─────────
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN
TELEGRAM_CHAT_ID=YOUR_TELEGRAM_CHAT_ID

# ── Google AI Studio (Gemini fallback) ───────────
GOOGLE_AI_STUDIO_API_KEY=YOUR_GOOGLE_AI_STUDIO_API_KEY

# ── Nexus Relay ───────────────────────────────────
NEXUS_RELAY_URL=https://nexus-relay-production.up.railway.app
NEXUS_SECRET=pantheon_prime

# ── GitHub ────────────────────────────────────────
GITHUB_TOKEN=YOUR_GITHUB_TOKEN

# ── Stripe ────────────────────────────────────────
STRIPE_SECRET_KEY=

# ── SearxNG / Vane (local search) ────────────────
SEARX_URL=http://localhost:3000

# ── Owner ─────────────────────────────────────────
OWNER_NAME=Forgemaster

# ── Debug ─────────────────────────────────────────
FILOS_DEBUG=false
